# ─── 行尾规范化 ──────────────────────────────────────────────────
# 源码在仓库和工作区都固定为 LF。把规则写进仓库,
# 不再依赖各机器的 core.autocrlf 全局设置,消除跨机器 CRLF/LF 抖动。
* text=auto

# ─── 明确文本类型(保险,避免被误判为二进制) ──────────────────────
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.jsonc text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.svg   text eol=lf
*.md    text eol=lf
*.py    text eol=lf
*.rs    text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.txt   text eol=lf
*.ini   text eol=lf

# Windows 脚本必须用 CRLF,否则部分环境执行异常
*.bat   text eol=crlf
*.ps1   text eol=crlf

# ─── 二进制文件(不做行尾转换,不做文本 diff) ─────────────────────
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.pdf   binary
*.docx  binary
*.xlsx  binary
